{
  "name": "@penpot/headless-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": { "pp": "bin/pp.mjs" },
  "scripts": {
    "build": "clojure -M:dev:shadow-cljs release headless",
    "watch": "clojure -M:dev:shadow-cljs watch headless",
    "test": "node scripts/run-tests.mjs",
    "test:unit": "node --test test/session.test.mjs test/facade.test.mjs test/script.test.mjs",
    "test:integration": "node --test --test-concurrency=1 test/workingcopy.roundtrip.test.mjs test/roundtrip.test.mjs",
    "test:e2e": "node --test --test-concurrency=1 test/mcp-server.test.mjs test/cli.test.mjs",
    "test:live": "node scripts/run-tests.mjs --live",
    "test:engine": "node scripts/test-engine.mjs",
    "verify": "node scripts/run-tests.mjs",
    "mcp": "node mcp/server.mjs",
    "sanity": "node scripts/sanity.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "date-fns": "^4.1.0",
    "zod": "^4.3.6"
  }
}
