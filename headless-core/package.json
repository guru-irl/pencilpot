{
  "name": "@penpot/headless-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": { "pp": "bin/pp.mjs" },
  "scripts": {
    "build": "clojure -M:dev:shadow-cljs release headless",
    "watch": "clojure -M:dev:shadow-cljs watch headless",
    "test:unit": "node --test test/session.test.mjs test/facade.test.mjs",
    "test:engine": "node scripts/test-engine.mjs",
    "test:roundtrip": "node --test test/workingcopy.roundtrip.test.mjs",
    "verify": "npm run build && npm run test:unit && node --test test/script.test.mjs && npm run test:engine && npm run test:roundtrip && npm run test:mcp",
    "mcp": "node mcp/server.mjs",
    "test:mcp": "node --test test/mcp-server.test.mjs",
    "test:cli": "node --test test/cli.test.mjs",
    "sanity": "node scripts/sanity.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "date-fns": "^4.1.0",
    "zod": "^4.3.6"
  }
}
